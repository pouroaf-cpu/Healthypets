# ─── Supabase (email signups + affiliate click tracking) ───
# Reusing the injectbuddy project; tables hp_subscribers / hp_clicks have INSERT-ONLY RLS.
# Use the PUBLISHABLE key ONLY. Do NOT put the service/secret key here — it bypasses RLS
# and would expose ALL injectbuddy data if this public site leaked it.
SUPABASE_URL=https://rktklvutvbombuajrvrv.supabase.co
SUPABASE_KEY=sb_publishable_j9ojkVxMOcj-d8zDy794YQ_xXJ8j8kG   # publishable/anon key (safe, insert-only)

# ─── Analytics (each activates only when its key is set) ───
NEXT_PUBLIC_GA_ID=                 # GA4 measurement id (G-XXXXXXX)
# PostHog: use the dedicated "Healthy Pets" PROJECT's API key (phc_...), NOT the
# injectbuddy "Default project". Same PostHog org, separate project = clean analytics.
# Find it in PostHog -> Settings -> Project -> Project API Key.
NEXT_PUBLIC_POSTHOG_KEY=           # phc_... from the Healthy Pets project
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_GSC_VERIFICATION=      # Google Search Console verification token
# Vercel Analytics needs no key — it activates automatically on Vercel deploys.

# ─── Email (MailerLite — re-treat reminder automation) ───
MAILERLITE_API_KEY=
MAILERLITE_GROUP_ID=               # optional: group for the reminder automation
